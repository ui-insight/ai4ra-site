---
import { withBase } from "../lib/paths";
---

<footer class="site-footer">
  <div class="shell footer-grid">
    <div>
      <p class="footer-kicker">AI4RA Community of Practice</p>
      <p class="footer-copy">
        Building open, trustworthy, practitioner-centered infrastructure for research
        administration.
      </p>
    </div>
    <div>
      <p class="footer-heading">Focus</p>
      <ul class="footer-list">
        <li>Interoperability</li>
        <li>Stewardship</li>
        <li>Responsible AI</li>
        <li>Shared public goods</li>
      </ul>
    </div>
    <div>
      <p class="footer-heading">Ecosystem</p>
      <ul class="footer-list">
        <li><a href={withBase("/open-source/#ai4ra-udm")}>AI4RA UDM</a></li>
        <li><a href={withBase("/open-source/#openera")}>OpenERA</a></li>
        <li><a href={withBase("/open-source/#vandalizer")}>Vandalizer</a></li>
      </ul>
    </div>
    <div>
      <p class="footer-heading">Participate</p>
      <ul class="footer-list">
        <li><a href={withBase("/resources/library/participation-guide/")}>Participation guide</a></li>
        <li><a href={withBase("/events/")}>Events and working sessions</a></li>
        <li>
          <a href="https://github.com/ui-insight/ai4ra-site" target="_blank" rel="noreferrer">
            Site repository
          </a>
        </li>
      </ul>
    </div>
  </div>
