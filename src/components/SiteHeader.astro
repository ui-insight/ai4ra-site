---
import { normalizePath, withBase } from "../lib/paths";

const navItems = [
  { href: "/", label: "Home" },
  { href: "/community/", label: "Community" },
  { href: "/practice-areas/", label: "Practice Areas" },
  { href: "/open-source/", label: "Open Source" },
  { href: "/resources/", label: "Resources" },
  { href: "/events/", label: "Events" },
  { href: "/about/", label: "About" }
];

const currentPath = normalizePath(Astro.url.pathname);
---

<header class="site-header">
  <div class="shell">
    <div class="brand-lockup">
      <a href={withBase("/")} style="display:flex;align-items:center;gap:0.6rem;">
        <img class="brand-logo" src={withBase("/ai4ra-logo.png")} alt="AI4RA logo" />
        <span class="brand-line">Open practice for research administration</span>
      </a>
    </div>
    <nav aria-label="Primary">
      <ul class="nav-list">
        {
          navItems.map((item) => (
            <li>
              <a
                class:list={["nav-link", currentPath === normalizePath(item.href) && "is-active"]}
                href={withBase(item.href)}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
