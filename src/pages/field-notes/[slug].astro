---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const notes = await getCollection("fieldNotes", ({ data }) => !data.draft);

  return notes.map((note) => ({
    params: { slug: note.slug },
    props: { note }
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: note.data.title,
  description: note.data.description,
  datePublished: note.data.publishDate.toISOString(),
  author: {
    "@type": "Organization",
    name: note.data.institution ?? "AI4RA Community"
  },
  publisher: {
    "@type": "Organization",
    name: "AI4RA"
  }
};
---

<BaseLayout
  title={`${note.data.title} | AI4RA`}
  description={note.data.description}
  type="article"
  structuredData={structuredData}
>
  <article class="article-shell">
    <div class="article-meta">
      <p class="eyebrow">Field note</p>
      <p class="meta-line">
        {note.data.publishDate.toLocaleDateString("en-US")}
        {note.data.institution ? ` · ${note.data.institution}` : ""}
      </p>
      <h1>{note.data.title}</h1>
      <p class="lede">{note.data.description}</p>
    </div>
    <div class="article-body">
      <Content />
    </div>
  </article>
</BaseLayout>
