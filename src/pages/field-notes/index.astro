---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const notes = (await getCollection("fieldNotes", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
---

<BaseLayout title="Field Notes | AI4RA">
  <section class="page-intro">
    <p class="eyebrow">Field notes</p>
    <h1>Grounded observations from implementation and community work.</h1>
    <p>
      Field notes should capture patterns, tensions, and practical lessons from real
      conversations and institutional contexts.
    </p>
  </section>

  <section class="content-block">
    <div class="stack-list">
      {
        notes.map((note) => (
          <article class="stack-card">
            <p class="meta-line">{note.data.publishDate.toLocaleDateString("en-US")}</p>
            <h2><a href={`/field-notes/${note.slug}/`}>{note.data.title}</a></h2>
            <p>{note.data.description}</p>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
