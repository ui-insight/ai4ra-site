---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const essays = (await getCollection("essays", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
const notes = (await getCollection("fieldNotes", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
const library = (await getCollection("resources", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
---

<BaseLayout title="Resources | AI4RA">
  <section class="page-intro">
    <p class="eyebrow">Resources</p>
    <h1>Make the site useful between events, conversations, and releases.</h1>
    <p>
      A community site earns repeat visits by helping people think and act. This
      section should become the library of practical materials, not just a document dump.
    </p>
  </section>

  <section class="content-block">
    <p class="eyebrow">Writing and library</p>
    <h2 class="section-heading">Use the library to make the work cumulative.</h2>
    <p class="section-copy">
      Essays hold the field’s arguments. Field notes preserve what institutions are
      learning in practice. Guides and governance resources reduce the cost of joining
      the ecosystem well. Over time this section should help people see not only what
      AI4RA is doing, but what the broader community is learning.
    </p>
    <div class="stack-list">
      <article class="stack-card">
        <p class="meta-line">Essays</p>
        <h2><a href="/essays">Essays and framing pieces</a></h2>
        <p>Principles, arguments, and durable language for the community.</p>
        {essays[0] && <p><a href={`/essays/${essays[0].slug}/`}>Latest: {essays[0].data.title}</a></p>}
      </article>
      <article class="stack-card">
        <p class="meta-line">Field notes</p>
        <h2><a href="/field-notes">Field notes and implementation observations</a></h2>
        <p>Grounded patterns and tensions from institutional practice.</p>
        {notes[0] && (
          <p><a href={`/field-notes/${notes[0].slug}/`}>Latest: {notes[0].data.title}</a></p>
        )}
      </article>
      {
        library.map((item) => (
          <article class="stack-card">
            <p class="meta-line">
              {item.data.publishDate.toLocaleDateString("en-US")} · {item.data.resourceType}
            </p>
            <h2><a href={`/resources/library/${item.slug}/`}>{item.data.title}</a></h2>
            <p>{item.data.description}</p>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
