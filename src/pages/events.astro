---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const events = (await getCollection("events", ({ data }) => !data.draft)).sort(
  (a, b) => a.data.start.getTime() - b.data.start.getTime()
);
---

<BaseLayout title="Events | AI4RA">
  <section class="page-intro">
    <p class="eyebrow">Events</p>
    <h1>Visible activity is how the community becomes believable.</h1>
    <p>
      Events should make participation concrete and leave a public trace. The site does
      not need a heavyweight event platform, but it does need a visible rhythm of shared
      work.
    </p>
  </section>

  <section class="content-block">
    <p class="eyebrow">Working rhythm</p>
    <h2 class="section-heading">Use event pages as records of what the community is actually doing.</h2>
    <p class="section-copy">
      Over time, event pages should accumulate agendas, materials, recordings, and short
      summaries so visitors can see that AI4RA is an active professional commons rather
      than a static project site.
    </p>
    <div class="stack-list">
      {
        events.map((event) => (
          <article class="stack-card">
            <p class="meta-line">
              {event.data.start.toLocaleString("en-US", {
                dateStyle: "long",
                timeStyle: "short"
              })}
              {" · "}
              {event.data.location}
            </p>
            <h2><a href={`/events/${event.slug}/`}>{event.data.title}</a></h2>
            <p>{event.data.description}</p>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
