---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const essays = await getCollection("essays", ({ data }) => !data.draft);

  return essays.map((essay) => ({
    params: { slug: essay.slug },
    props: { essay }
  }));
}

const { essay } = Astro.props;
const { Content } = await render(essay);
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: essay.data.title,
  description: essay.data.description,
  datePublished: essay.data.publishDate.toISOString(),
  author: {
    "@type": "Organization",
    name: essay.data.author
  },
  publisher: {
    "@type": "Organization",
    name: "AI4RA"
  }
};
---

<BaseLayout
  title={`${essay.data.title} | AI4RA`}
  description={essay.data.description}
  type="article"
  structuredData={structuredData}
>
  <article class="article-shell">
    <div class="article-meta">
      <p class="eyebrow">Essay</p>
      <p class="meta-line">
        {essay.data.publishDate.toLocaleDateString("en-US")} · {essay.data.author}
      </p>
      <h1>{essay.data.title}</h1>
      <p class="lede">{essay.data.description}</p>
    </div>
    <div class="article-body">
      <Content />
    </div>
  </article>
</BaseLayout>
