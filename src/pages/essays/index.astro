---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const essays = (await getCollection("essays", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
---

<BaseLayout title="Essays | AI4RA">
  <section class="page-intro">
    <p class="eyebrow">Essays</p>
    <h1>Arguments, principles, and durable framing for the field.</h1>
    <p>
      Use essays for the pieces that define why the community exists, what it values,
      and how the ecosystem should evolve.
    </p>
  </section>

  <section class="content-block">
    <div class="stack-list">
      {
        essays.map((essay) => (
          <article class="stack-card">
            <p class="meta-line">{essay.data.publishDate.toLocaleDateString("en-US")}</p>
            <h2><a href={`/essays/${essay.slug}/`}>{essay.data.title}</a></h2>
            <p>{essay.data.description}</p>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
