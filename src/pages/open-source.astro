---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = (await getCollection("releases", ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout title="Open Source | AI4RA">
  <section class="page-intro">
    <p class="eyebrow">Open source</p>
    <h1>Software as shared infrastructure for the community.</h1>
    <p>
      The release pages should connect code to purpose: why the community needs each
      project, what values shaped it, and how institutions can evaluate, pilot, or
      contribute.
    </p>
  </section>

  <section class="content-block">
    <div class="release-grid">
      {
        projects.map((project) => (
          <article class="release-card" id={project.slug}>
            <span class="tag">{project.data.status}</span>
            <h3><a href={`/open-source/${project.slug}/`}>{project.data.title}</a></h3>
            <p>{project.data.description}</p>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
